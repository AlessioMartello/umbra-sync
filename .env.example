# Umbra Sync Environment Variables
# Copy this file to .env and fill in your own values

# === REQUIRED: Outlook / Azure Configuration ===
# Azure Client ID for OAuth2 authentication
# Get from: https://portal.azure.com -> App registrations -> [Your app] -> Application (client) ID
AZURE_CLIENT_ID=your_azure_client_id_here

# Outlook refresh token for persistent authentication
# Obtain via msal library (one-time setup)
REFRESH_TOKEN=your_refresh_token_here

# === REQUIRED: Monday.com Configuration ===
# Monday.com personal API token
# Get from: Monday workspace -> Settings -> API -> Create API Token
MONDAY_API_KEY=your_monday_api_key_here

# Monday.com board ID for contacts
# Get from: Open your contact board in Monday -> Board ID is in the URL (board/12345)
MONDAY_BOARD_ID=1234567890

# === OPTIONAL: Runtime Configuration ===
# Enable debug logging (verbose output)
# Values: true, false
DEBUG=false

# Rate limit delay (seconds) between email processing
# Adjust based on API rate limits and Groq token usage
RATE_LIMIT_DELAY_SEC=15
